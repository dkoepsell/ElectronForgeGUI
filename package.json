{
  "name": "electron-forge-v4",
  "version": "4.0.0",
  "description": "GUI tool to package web, Python, R, and notebook apps as desktop executables",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node server.js",
    "build:win": "pkg server.js --target node18-win-x64 --output dist/ElectronForgeV4.exe --compress GZip",
    "build:mac": "pkg server.js --target node18-macos-x64 --output dist/ElectronForgeV4-mac --compress GZip",
    "build:linux": "pkg server.js --target node18-linux-x64 --output dist/ElectronForgeV4-linux --compress GZip",
    "build:all": "pkg server.js --targets node18-win-x64,node18-macos-x64,node18-linux-x64 --output dist/ElectronForgeV4 --compress GZip"
  },
  "pkg": {
    "assets": [
      "public/**/*"
    ],
    "targets": [
      "node18-win-x64"
    ],
    "outputPath": "dist",
    "compress": "GZip"
  },
  "dependencies": {
    "express": "^4.18.2",
    "multer": "^1.4.5-lts.1",
    "ws": "^8.14.2",
    "archiver": "^6.0.1",
    "extract-zip": "^2.0.1"
  },
  "devDependencies": {
    "pkg": "^5.8.1",
    "electron-builder": "^24.9.1"
  },
  "keywords": [
    "electron",
    "builder",
    "gui",
    "packaging"
  ],
  "license": "MIT"
}
